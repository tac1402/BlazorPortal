@inherits ErrorBoundary

@if (CurrentException is null)
{
    @ChildContent
}
else
{
    <div style="background-color: #ffcccc; border: 2px solid red; padding: 15px; margin: 10px; white-space: pre-wrap;">
        <strong>Error:</strong>
        <div>@CurrentException.Message</div>
        @if (!string.IsNullOrEmpty(CurrentException.StackTrace))
        {
            <details>
                <summary>Details...</summary>
                <pre style="margin-top: 10px;">@CurrentException.StackTrace</pre>
            </details>
        }
    </div>
}